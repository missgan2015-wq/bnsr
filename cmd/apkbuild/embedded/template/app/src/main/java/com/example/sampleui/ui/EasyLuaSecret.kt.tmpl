package com.example.sampleui.ui

/**
 * 资源加密密钥与解密工具（apkbuild 渲染期生成）。
 *
 * 工程脚本里勿手改：本文件由 apkbuild RenderTemplate 把 lj_obfus_table.h 里
 * LJ_OBFUS_RES_KEY[16] 抽出来灌进占位符 [[RES_KEY_BYTES]]。
 *
 * 算法与 Backport_Project/src/lj_obfus.c::lj_obfus_res_xor、apkbuild 端
 * encrypt.go::ResXor 完全同构（流式 XOR + carry chain 自反），三端共用同一套
 * 16 字节 key + 算法。
 *
 * 用途：
 *   - DialogActivity 读 ui.lua.enc → decrypt() 得到 ui.lua 源码
 *   - ScriptRunner.onDialogResult / onHeadlessDialogResult 回写时反向加密
 */
internal object EasyLuaSecret {

    /** 16 字节资源加密 key，由 apkbuild 渲染期填入。 */
    private val KEY: ByteArray = {{RES_KEY_BYTES}}

    /**
     * 流式 XOR 解 / 加密（自反）。salt 固定 0 与 PC 端、native 端对齐。
     * 输入会被原地修改；如需保留原数据请自行 .copyOf() 后传入。
     */
    fun xorInPlace(data: ByteArray, salt: Int = 0) {
        val len = data.size
        var carry = ((len * 31) + (salt * 17) + 0x5A) and 0xFF
        for (i in 0 until len) {
            val k = KEY[((i + carry) and 15)].toInt() and 0xFF
            data[i] = (data[i].toInt() xor k).toByte()
            carry = (carry + k + i) and 0xFF
        }
    }

    /** 解密 .enc 文件字节 → 原始字节。salt 固定 0。 */
    fun decrypt(encrypted: ByteArray, salt: Int = 0): ByteArray {
        val out = encrypted.copyOf()
        xorInPlace(out, salt)
        return out
    }

    /** 加密原始字节 → .enc 字节。 */
    fun encrypt(plain: ByteArray, salt: Int = 0): ByteArray {
        val out = plain.copyOf()
        xorInPlace(out, salt)
        return out
    }

    /** 把字符串 UTF-8 编码后加密。 */
    fun encryptString(s: String, salt: Int = 0): ByteArray =
        encrypt(s.toByteArray(Charsets.UTF_8), salt)

    /** 解密后按 UTF-8 解码成字符串（适用于 ui.lua.enc 等文本类资源）。 */
    fun decryptToString(encrypted: ByteArray, salt: Int = 0): String =
        String(decrypt(encrypted, salt), Charsets.UTF_8)
}
